---
import Base from '../layouts/Base.astro';
import { CATEGORIES, whatsappLink } from '../config/categories';
import { organizationSchema, webSiteSchema } from '../lib/seo';

const title = 'SkillKite — Free AI career guidance for Indian students';
const description =
  'From choosing a stream after 10th to landing your first job after a degree — get a clear, personalized plan you can actually follow. Free, in Hindi + English.';

const orgJson = JSON.stringify(organizationSchema(Astro.site!));
const siteJson = JSON.stringify(webSiteSchema(Astro.site!));
---

<Base title={title} description={description} path="/">
  <!-- Hero -->
  <section class="hero">
    <div class="hero-inner">
      <span class="eyebrow">Free · AI-powered · Hindi + English</span>
      <h1>
        <span class="brandline">Right skills. Higher reach.</span>
        Your career, figured out.
      </h1>
      <p class="sub">
        Tell us where you are. Get a personalized plan — stream, course, or full career
        roadmap — with free resources to follow.
      </p>
      <div class="ctas">
        <a class="btn-wa" href={whatsappLink()}>💬 Chat on WhatsApp</a>
        <a class="btn-br" href="#browse">Browse guidance →</a>
      </div>
    </div>
  </section>

  <!-- Category cards -->
  <section class="cards-wrap" id="browse">
    <div class="cards-head">
      <h2>Pick your stage</h2>
      <p>Four paths. One clear next step for each — read your options and download a guide.</p>
    </div>
    <div class="grid">
      {
        CATEGORIES.map((c) => (
          <a class={`card ${c.card}`} href={`/${c.slug}`}>
            <div class="emoji">{c.emoji}</div>
            <h3>{c.title}</h3>
            <p>{c.blurb}</p>
            <div class="go">{c.cta}</div>
          </a>
        ))
      }
    </div>
  </section>

  <!-- Why SkillKite -->
  <section class="why-section">
    <div class="why-head">
      <span class="why-label">Why SkillKite</span>
      <h2>Everything you need. Nothing you don't.</h2>
      <p>Built for students from Tier 2/3 cities who need clear, honest career guidance — not ads or upsells.</p>
    </div>
    <div class="why-grid">
      <div class="why-card">
        <div class="why-icon">🤖</div>
        <h3>AI Career Coaching</h3>
        <p>Smart, conversational guidance that understands your background, goals, and constraints — not a generic quiz result.</p>
      </div>
      <div class="why-card">
        <div class="why-icon">🗺️</div>
        <h3>Personalized Roadmaps</h3>
        <p>A step-by-step plan tailored to your degree, stream, and career goal — with free resources for every step.</p>
      </div>
      <div class="why-card">
        <div class="why-icon">🇮🇳</div>
        <h3>Hindi + English</h3>
        <p>Chat in whatever feels natural. Mix languages, use Hinglish — SkillKite understands.</p>
      </div>
      <div class="why-card">
        <div class="why-icon">📱</div>
        <h3>WhatsApp First</h3>
        <p>No app download, no signup, no email. Just open WhatsApp and say Hi. That's it.</p>
      </div>
      <div class="why-card">
        <div class="why-icon">🔒</div>
        <h3>Privacy First</h3>
        <p>Type "reset" anytime to delete all your data. No tracking, no selling your info. Your data, your call.</p>
      </div>
      <div class="why-card">
        <div class="why-icon">🆓</div>
        <h3>100% Free</h3>
        <p>No hidden charges, no premium plan, no "upgrade to unlock." Career guidance should be accessible to everyone.</p>
      </div>
    </div>
  </section>

  <script type="application/ld+json" is:inline set:html={orgJson} />
  <script type="application/ld+json" is:inline set:html={siteJson} />
</Base>
