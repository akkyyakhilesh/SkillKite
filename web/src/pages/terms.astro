---
import Base from '../layouts/Base.astro';
---

<Base title="Terms of Use — SkillKite" description="SkillKite terms of use. Free AI career guidance via WhatsApp." path="/terms">
  <section class="guide" style="max-width:680px; padding-top:48px;">
    <h1 style="font-size:32px; font-weight:900; margin-bottom:28px;">Terms of Use</h1>

    <div class="guide-section">
      <h2 class="sec-title">Service</h2>
      <p style="color:var(--muted); line-height:1.7;">
        SkillKite provides free AI-powered career guidance via WhatsApp and this website. The guidance is informational and does not constitute professional career counselling. Always verify important decisions with qualified advisors or official sources.
      </p>
    </div>

    <div class="guide-section">
      <h2 class="sec-title">Use of the service</h2>
      <p style="color:var(--muted); line-height:1.7;">
        SkillKite is intended for students and professionals in India seeking career guidance. By using this service you agree not to misuse it, attempt to extract or reverse-engineer the underlying AI system, or use it for any unlawful purpose.
      </p>
    </div>

    <div class="guide-section">
      <h2 class="sec-title">Accuracy</h2>
      <p style="color:var(--muted); line-height:1.7;">
        Career information — including salary bands, entrance exams, and timelines — is based on publicly available data and AI-generated estimates. It may not reflect current market conditions. SkillKite makes no guarantees about outcomes.
      </p>
    </div>

    <div class="guide-section">
      <h2 class="sec-title">Changes</h2>
      <p style="color:var(--muted); line-height:1.7;">
        We may update these terms at any time. Continued use of the service after changes constitutes acceptance.
      </p>
    </div>

    <div class="guide-section">
      <h2 class="sec-title">Contact</h2>
      <p style="color:var(--muted); line-height:1.7;">
        Questions? Email <a href="mailto:hello@skillkite.in" style="color:var(--saffron-light); text-decoration:underline;">hello@skillkite.in</a>
      </p>
    </div>
  </section>
</Base>
