---
import Base from '../../layouts/Base.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { whatsappLink, CAREER_CATEGORIES, slugify, inr } from '../../config/categories';
import careers from '../../data/careers.json';

export function getStaticPaths() {
  return careers.map((c) => ({ params: { career: slugify(c.Title) }, props: { career: c } }));
}

const { career } = Astro.props;
const cat = CAREER_CATEGORIES.find((g) => g.key === career.Category);
const title = `${career.Title} — career path, salary & roadmap | SkillKite`;
const description = `${career.Description} Salary ${inr(career.SalaryRangeMin)}–${inr(career.SalaryRangeMax)}/month, ${career.DemandLevel.toLowerCase()} demand, job-ready in ${career.TimeToJobReady}. Free personalized roadmap.`;

const breadcrumbs = [
  { name: 'Home', path: '/' },
  { name: 'Graduation', path: '/after-graduation' },
  { name: career.Title, path: `/after-graduation/${slugify(career.Title)}` },
];
---

<Base title={title} description={description} path={`/after-graduation/${slugify(career.Title)}`}>
  <Breadcrumbs items={breadcrumbs} />

  <section class="hero hero--sub">
    <div class="hero-inner">
      <span class="eyebrow">{cat?.emoji} {cat?.label ?? 'Career'}</span>
      <h1>{career.Title}</h1>
      <p class="sub">{career.Description}</p>
      <div class="ctas">
        <a class="btn-wa" href={whatsappLink(`Hi SkillKite! I want a roadmap for ${career.Title}`)}>
          💬 Get my free roadmap
        </a>
        <a class="btn-br" href="/after-graduation">← All careers</a>
      </div>
    </div>
  </section>

  <section class="guide">
    <div class="stat-grid">
      <div class="stat">
        <span class="stat-label">💰 Salary range</span>
        <span class="stat-value">{inr(career.SalaryRangeMin)}–{inr(career.SalaryRangeMax)}<small>/month</small></span>
      </div>
      <div class="stat">
        <span class="stat-label">📈 Demand</span>
        <span class="stat-value">{career.DemandLevel}</span>
      </div>
      <div class="stat">
        <span class="stat-label">⏱️ Time to job-ready</span>
        <span class="stat-value">{career.TimeToJobReady}</span>
      </div>
      <div class="stat">
        <span class="stat-label">🌍 Work style</span>
        <span class="stat-value">{career.RemoteFriendly ? 'Remote-friendly' : 'On-site'}</span>
      </div>
    </div>

    <div class="roadmap-cta">
      <h2 class="sec-title">Your week-by-week roadmap</h2>
      <p>
        SkillKite builds you a personalized, week-by-week plan for {career.Title} — the skills
        to learn in order, free learning resources for each, and practice projects. It's based
        on a 2-minute chat about where you're starting from.
      </p>
      <a class="btn-wa" href={whatsappLink(`Hi SkillKite! I want a roadmap for ${career.Title}`)}>
        💬 Get my free roadmap on WhatsApp
      </a>
    </div>
  </section>
</Base>
