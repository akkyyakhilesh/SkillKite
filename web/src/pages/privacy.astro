---
import Base from '../layouts/Base.astro';
---

<Base title="Privacy Policy — SkillKite" description="SkillKite privacy policy. We collect only what's needed to give you career guidance via WhatsApp." path="/privacy" noindex={true}>
  <section class="guide" style="max-width:680px; padding-top:48px;">
    <h1 style="font-size:32px; font-weight:900; margin-bottom:28px;">Privacy Policy</h1>

    <div class="guide-section">
      <h2 class="sec-title">What we collect</h2>
      <p style="color:var(--muted); line-height:1.7; margin-bottom:12px;">
        When you chat with SkillKite on WhatsApp, we store your WhatsApp phone number and the messages you send us. This is used solely to provide career guidance and remember your progress across sessions.
      </p>
      <p style="color:var(--muted); line-height:1.7;">
        We do not collect your name, email, or any payment information.
      </p>
    </div>

    <div class="guide-section">
      <h2 class="sec-title">How we use it</h2>
      <p style="color:var(--muted); line-height:1.7;">
        Your data is used only to generate personalized career guidance. We do not sell or share your data with any third party. Career PDFs generated for you are stored temporarily to enable WhatsApp delivery.
      </p>
    </div>

    <div class="guide-section">
      <h2 class="sec-title">Deleting your data</h2>
      <p style="color:var(--muted); line-height:1.7;">
        Type <strong style="color:#fff;">reset</strong> in the SkillKite WhatsApp chat at any time to permanently delete all data we hold about you.
      </p>
    </div>

    <div class="guide-section">
      <h2 class="sec-title">Contact</h2>
      <p style="color:var(--muted); line-height:1.7;">
        Questions? Email us at <a href="mailto:hello@skillkite.in" style="color:var(--saffron-light); text-decoration:underline;">hello@skillkite.in</a>
      </p>
    </div>
  </section>
</Base>
