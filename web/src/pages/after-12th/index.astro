---
import Base from '../../layouts/Base.astro';
import PickerView from '../../components/PickerView.astro';
import { TWELFTH_STREAMS } from '../../config/categories';

const title = 'After 12th — choose your stream | SkillKite';
const description =
  'After 12th, your options depend on your stream. Pick PCM, PCB, Commerce, Arts or BBA to see every course, entrance exam and career path — honestly laid out, free.';

const items = TWELFTH_STREAMS.map((s) => ({
  href: `/after-12th/${s.slug}`,
  emoji: s.emoji,
  title: s.label,
  blurb: s.blurb,
}));
---

<Base title={title} description={description} path="/after-12th">
  <PickerView
    eyebrow="🎯 After 12th"
    heading="Which stream did you take?"
    intro="Your options after 12th depend on your stream. Pick yours to see every course, entrance exam and career — all on one page."
    items={items}
    breadcrumbs={[
      { name: 'Home', path: '/' },
      { name: 'After 12th', path: '/after-12th' },
    ]}
    escapePrompt="Not sure which fits you?"
    escapeWaText="Hi SkillKite! Help me choose after 12th"
  />
</Base>
