---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import GuideView from '../../components/GuideView.astro';

export async function getStaticPaths() {
  const guides = await getCollection('guides', (g) => g.data.category === 'after-12th');
  return guides.map((g) => ({ params: { stream: g.data.stream }, props: { entry: g.data } }));
}

const { entry } = Astro.props;
const { streamLabel, seoTitle, seoDescription, stream, guide } = entry;
---

<Base title={seoTitle} description={seoDescription} path={`/after-12th/${stream}`}>
  <GuideView
    eyebrow={`🎯 After 12th · ${streamLabel}`}
    heading={`${streamLabel} — your options`}
    intro={`Every realistic course, entrance exam and career path after 12th ${streamLabel}. Tap any option to see details. Honest timelines, no hype.`}
    pdfWaText={`Hi SkillKite! I'm 12th ${streamLabel} — send me the guide`}
    backHref="/after-12th"
    backLabel="Other streams"
    sections={guide.sections}
    escapePrompt="Want this personalized to you, with free learning resources?"
    escapeWaText={`Hi SkillKite! I'm 12th ${streamLabel}`}
  />
</Base>
