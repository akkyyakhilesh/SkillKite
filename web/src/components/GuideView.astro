---
import { whatsappLink } from '../config/categories';
import { breadcrumbListSchema, faqPageSchema, type Crumb } from '../lib/seo';

interface Option {
  name: string;
  whatIsIt: string;
  whoFor: string;
  leadsTo: string;
  keyExams: string;
  timeCommitment: string;
}
interface Section {
  title: string;
  intro?: string | null;
  options: Option[];
}

export interface Props {
  eyebrow: string;
  heading: string;
  intro: string;
  pdfWaText: string;
  backHref: string;
  backLabel: string;
  sections: Section[];
  escapePrompt: string;
  escapeWaText: string;
  /** Breadcrumb trail (Home → category → this page) for the visible UI + JSON-LD. */
  breadcrumbs: Crumb[];
}

const { eyebrow, heading, intro, pdfWaText, backHref, backLabel, sections, escapePrompt, escapeWaText, breadcrumbs } =
  Astro.props;

// Structured data: the option cards are FAQ-shaped, and every guide sits under
// a clear Home → category → page trail. Both rendered as JSON-LD below.
const faqJson = JSON.stringify(faqPageSchema(sections));
const breadcrumbJson = JSON.stringify(breadcrumbListSchema(Astro.site!, breadcrumbs));

// Short preview line for the collapsed card — first sentence of "leads to".
const preview = (s: string) => {
  const first = s.split(/(?<=[.!?])\s/)[0] ?? s;
  return first.length > 110 ? first.slice(0, 107).trimEnd() + '…' : first;
};
---

<nav class="crumbs" aria-label="Breadcrumb">
  {breadcrumbs.map((c, i) => (
    <>
      {i > 0 && <span class="crumb-sep" aria-hidden="true">›</span>}
      {i < breadcrumbs.length - 1 ? (
        <a href={c.path}>{c.name}</a>
      ) : (
        <span aria-current="page">{c.name}</span>
      )}
    </>
  ))}
</nav>

<section class="hero hero--sub">
  <div class="hero-inner">
    <span class="eyebrow">{eyebrow}</span>
    <h1>{heading}</h1>
    <p class="sub">{intro}</p>
    <div class="ctas">
      <a class="btn-wa" href={whatsappLink(pdfWaText)}>💬 Get this as a PDF on WhatsApp</a>
      <a class="btn-br" href={backHref}>← {backLabel}</a>
    </div>
  </div>
</section>

<nav class="sec-nav">
  {sections.map((section) => (
    <a class="sec-pill" href={`#${section.title.toLowerCase().replace(/[^a-z0-9]+/g, '-')}`}>
      {section.title}
    </a>
  ))}
</nav>

<section class="guide">
  {
    sections.map((section) => (
      <div class="guide-section" id={section.title.toLowerCase().replace(/[^a-z0-9]+/g, '-')}>
        <h2 class="sec-title">{section.title}</h2>
        {section.intro && <p class="sec-intro">{section.intro}</p>}

        {section.options.map((o) => (
          <details class="opt">
            <summary>
              <span class="opt-head">
                <span class="opt-name">{o.name}</span>
                <span class="opt-preview">{preview(o.whatIsIt || o.leadsTo)}</span>
              </span>
              <span class="opt-chev" aria-hidden="true">▸</span>
            </summary>
            <div class="opt-body">
              {o.whatIsIt && <p><span class="ic">❓</span>{o.whatIsIt}</p>}
              {o.whoFor && <p><span class="ic">👤</span>{o.whoFor}</p>}
              {o.leadsTo && <p><span class="ic">➡️</span>{o.leadsTo}</p>}
              {o.keyExams && <p><span class="ic">📜</span>{o.keyExams}</p>}
              {o.timeCommitment && <p><span class="ic">⏱️</span>{o.timeCommitment}</p>}
            </div>
          </details>
        ))}
      </div>
    ))
  }

  <div class="escape">
    <p>{escapePrompt}</p>
    <a class="btn-wa" href={whatsappLink(escapeWaText)}>💬 Chat on WhatsApp</a>
  </div>
</section>

<script type="application/ld+json" is:inline set:html={faqJson} />
<script type="application/ld+json" is:inline set:html={breadcrumbJson} />

<style>
  .crumbs {
    max-width: 980px;
    margin: 0 auto;
    padding: 18px 20px 0;
    font-size: 13px;
    color: var(--muted);
  }
  .crumbs a {
    color: var(--muted);
    text-decoration: none;
  }
  .crumbs a:hover {
    color: var(--saffron-light);
    text-decoration: underline;
  }
  .crumbs [aria-current='page'] {
    color: var(--ink, #e8ecf6);
  }
  .crumb-sep {
    margin: 0 8px;
    opacity: 0.5;
  }
</style>
